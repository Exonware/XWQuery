SELECT ?name ?email ?order_count ?lifetime_value ?last_order_date ?customer_tier WHERE { ?user_stat :name ?name . ?user_stat :email ?email . ?user_stat :order_count ?order_count . ?user_stat :lifetime_value ?lifetime_value . ?user_stat :last_order_date ?last_order_date . ?user_stat :customer_tier ?customer_tier . FILTER(?active = ?true ?AND ?o.?status ?IN ('?completed', '?shipped') ?AND ?us.?order_count > ?0) }